@baseUrl = http://localhost:2006
@token = PASTE_ACCESS_TOKEN_HERE
@userSkillId = PASTE_USER_SKILL_UUID_HERE
@targetUserId = PASTE_OTHER_USER_UUID_HERE

### ─── 1. Your Profile ───

### Get your own profile information
GET {{baseUrl}}/users/me
Authorization: Bearer {{token}}

### Update your city and bio
PATCH {{baseUrl}}/users/me
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "city": "Casablanca",
  "bio": "Développeur fullstack passionné par les échanges de compétences."
}

### Update your first and last name
PATCH {{baseUrl}}/users/me
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "firstName": "Zakariae",
  "lastName": "Skilo"
}

### Update your profile picture
PATCH {{baseUrl}}/users/me
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "avatarUrl": "https://res.cloudinary.com/skilo/image/upload/v1/avatars/sample.jpg"
}

### Test: Try to update with a bio that is too long
PATCH {{baseUrl}}/users/me
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "bio": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
}

### Delete your account
DELETE {{baseUrl}}/users/me
Authorization: Bearer {{token}}


### ─── 2. Your Skills ───

### Add a skill that you can teach
POST {{baseUrl}}/users/me/skills
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "skillId": "PASTE_SKILL_UUID_HERE",
  "type": "offered",
  "level": "intermediate"
}

### Add a skill that you want to learn
POST {{baseUrl}}/users/me/skills
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "skillId": "PASTE_SKILL_UUID_HERE",
  "type": "wanted",
  "level": "beginner"
}

### Test: Try to add a skill with an invalid level
POST {{baseUrl}}/users/me/skills
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "skillId": "PASTE_SKILL_UUID_HERE",
  "type": "offered",
  "level": "expert"
}

### Test: Try to add a skill with an invalid type
POST {{baseUrl}}/users/me/skills
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "skillId": "PASTE_SKILL_UUID_HERE",
  "type": "teacher",
  "level": "beginner"
}

### Test: Try to add a skill that doesn't exist in the catalog
POST {{baseUrl}}/users/me/skills
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "skillId": "00000000-0000-0000-0000-000000000000",
  "type": "offered",
  "level": "beginner"
}

### Change the level of one of your skills
PATCH {{baseUrl}}/users/me/skills/{{userSkillId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "level": "advanced"
}

### Test: Try to change a skill using an invalid ID
PATCH {{baseUrl}}/users/me/skills/not-a-uuid
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "level": "advanced"
}

### Remove a skill from your profile
DELETE {{baseUrl}}/users/me/skills/{{userSkillId}}
Authorization: Bearer {{token}}

### Test: Try to remove a skill that is currently being used in a session
DELETE {{baseUrl}}/users/me/skills/{{userSkillId}}
Authorization: Bearer {{token}}


### ─── 3. Other Users Profiles ───

### Get a list of all active users
GET {{baseUrl}}/users
Authorization: Bearer {{token}}

### Get a list of users (Page 2)
GET {{baseUrl}}/users?page=2&limit=10
Authorization: Bearer {{token}}

### View another user's profile
GET {{baseUrl}}/users/{{targetUserId}}
Authorization: Bearer {{token}}

### Test: Try to view a user that doesn't exist
GET {{baseUrl}}/users/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{token}}

### Test: Try to view a user with an invalid ID
GET {{baseUrl}}/users/not-a-uuid
Authorization: Bearer {{token}}


### ─── 4. The Skill Catalog ───

### Search for a skill in the catalog
GET {{baseUrl}}/skills/search?q=java
Authorization: Bearer {{token}}

### Search for a skill with a partial word
GET {{baseUrl}}/skills/search?q=py
Authorization: Bearer {{token}}

### Search with an empty query (returns an empty list)
GET {{baseUrl}}/skills/search?q=
Authorization: Bearer {{token}}

### Suggest a brand new skill to be added to the catalog
POST {{baseUrl}}/skills
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Darija marocaine",
  "category": "languages"
}

### Test: Try to suggest a skill with an invalid category
POST {{baseUrl}}/skills
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Some Skill",
  "category": "music"
}

### Test: Try to suggest a skill that already exists
POST {{baseUrl}}/skills
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Darija marocaine",
  "category": "languages"
}
