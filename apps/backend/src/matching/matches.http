@adminToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMTAwMDAwMC0wMDAwLTAwMDAtMDAwMC0wMDAwMDAwMDAwMDIiLCJlbWFpbCI6Im1lcmllbUBza2lsby5hcHAiLCJmaXJzdE5hbWUiOiJNZXJpZW0iLCJsYXN0TmFtZSI6Ik91YWxpIiwicm9sZSI6ImFkbWluIiwiaWF0IjoxNzc2MDE3NDk5LCJleHAiOjE3NzYwMTgzOTl9.cNvWMQpyxrgsJJTNvt-i9uqPi-qb1G4LOV02HK6hlwg
