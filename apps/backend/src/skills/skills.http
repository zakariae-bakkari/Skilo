@adminToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMTAwMDAwMC0wMDAwLTAwMDAtMDAwMC0wMDAwMDAwMDAwMDIiLCJlbWFpbCI6Im1lcmllbUBza2lsby5hcHAiLCJmaXJzdE5hbWUiOiJNZXJpZW0iLCJsYXN0TmFtZSI6Ik91YWxpIiwicm9sZSI6ImFkbWluIiwiaWF0IjoxNzc2MDE1MzMwLCJleHAiOjE3NzYwMTYyMzB9.StwBK0jAA9UauOSmxVkbulNl35Sndw-2zhb8sEM_iaU
